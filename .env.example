# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://blog:blogpass@localhost:5433/blog"

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# ── Gemini AI (article generation) ───────────────────────────────────────────
GEMINI_API_KEY=

# ── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Docker/production only — server-side URL from Next.js container to backend container.
# Example: http://backend:4000 (local docker) or http://blogcraft-backend:4000 (prod)
API_URL=
